<style>
    *{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Poppins',sans-serif;
    overflow-x:hidden;
}

/*==========================
Navbar
==========================*/

.navbar{
    padding:18px 0;
    transition:.3s;
    background:#fff;
}

.navbar-brand img{
    height:58px;
}

.navbar-nav .nav-link{
    color:#222;
    font-size:17px;
    font-weight:500;
    margin:0 12px;
    position:relative;
    transition:.3s;
}

.navbar-nav .nav-link:hover,
.navbar-nav .nav-link.active{
    color:#0d6efd;
}

.navbar-nav .nav-link::after{
    content:"";
    position:absolute;
    left:0;
    bottom:-8px;
    width:0;
    height:2px;
    background:#0d6efd;
    transition:.3s;
}

.navbar-nav .nav-link:hover::after,
.navbar-nav .nav-link.active::after{
    width:100%;
}

/*==========================
Social Icons
==========================*/

.social-icons{
    display:flex;
    gap:15px;
}

.social-icons a{
    width:44px;
    height:44px;
    border-radius:50%;
    border:1px solid #ddd;
    display:flex;
    justify-content:center;
    align-items:center;
    color:#111;
    text-decoration:none;
    transition:.3s;
    font-size:18px;
}

.social-icons a:hover{
    background:#0d6efd;
    color:#fff;
    border-color:#0d6efd;
}

/*==========================
Hero
==========================*/

.hero{
    position:relative;
    min-height:100vh;
    background:url("656670.jpg") center center/cover no-repeat;
    display:flex;
    align-items:center;
}

.overlay{
    position:absolute;
    inset:0;
    background:rgba(0,25,60,.72);
}

.hero .container{
    position:relative;
    z-index:2;
}

.hero-small{
    color:#1f8cff;
    font-size:18px;
    font-weight:600;
    letter-spacing:3px;
    display:inline-block;
    border-bottom:2px solid #1f8cff;
    padding-bottom:8px;
    margin-bottom:30px;
}

.hero h1{
    color:#fff;
    font-size:78px;
    font-weight:800;
    line-height:1.1;
}

.hero h1 span{
    color:#0d6efd;
}

.hero p{
    color:#d7d7d7;
    font-size:24px;
    line-height:1.8;
    margin:35px 0;
    max-width:760px;
}

.hero-buttons{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
}

.hero-buttons .btn{
    padding:16px 36px;
    border-radius:6px;
    font-size:18px;
    font-weight:600;
}

.btn-primary{
    background:#0d6efd;
    border:none;
}

.btn-primary:hover{
    background:#0b5ed7;
}

.btn-outline-light:hover{
    color:#000;
}

/*==========================
Scroll
==========================*/

.scroll-text{
    position:absolute;
    left:50%;
    bottom:25px;
    transform:translateX(-50%);
    color:#fff;
    text-align:center;
    letter-spacing:3px;
    font-size:14px;
    z-index:5;
}

.scroll-text .line{
    width:2px;
    height:55px;
    background:#fff;
    margin:12px auto 0;
    animation:scrollLine 1.8s infinite;
}

@keyframes scrollLine{

0%{
height:15px;
opacity:.3;
}

50%{
height:55px;
opacity:1;
}

100%{
height:15px;
opacity:.3;
}

}

/*==========================
About
==========================*/

#about{
    padding:100px 0;
}

#about h2{
    font-size:42px;
    font-weight:700;
    margin-bottom:20px;
}

#about p{
    color:#666;
    font-size:18px;
    line-height:1.9;
}

/*==========================
Gallery
==========================*/

.gallery-section{
    padding:90px 0;
    background:#f7f9fc;
}

.gallery-section .section-title{
    font-size:42px;
    font-weight:700;
    color:#0f172a;
    margin-bottom:12px;
}

.gallery-section .section-text{
    color:#64748b;
    max-width:700px;
    margin:0 auto 40px;
}

.gallery-card{
    background:#fff;
    border-radius:16px;
    overflow:hidden;
    box-shadow:0 10px 30px rgba(15,23,42,.08);
    transition:transform .3s ease, box-shadow .3s ease;
    height:100%;
}

.gallery-card:hover{
    transform:translateY(-5px);
    box-shadow:0 18px 40px rgba(15,23,42,.12);
}

.gallery-card img{
    width:100%;
    height:260px;
    object-fit:cover;
}

.gallery-card-body{
    padding:18px;
}

.gallery-card-body h5{
    font-size:18px;
    font-weight:600;
    color:#0f172a;
    margin-bottom:8px;
}

.gallery-card-body p{
    color:#64748b;
    font-size:14px;
    margin:0;
}

/*==========================
WhatsApp
==========================*/

.whatsapp{
    position:fixed;
    right:25px;
    bottom:25px;
    width:65px;
    height:65px;
    background:#25D366;
    border-radius:50%;
    display:flex;
    justify-content:center;
    align-items:center;
    color:#fff;
    text-decoration:none;
    font-size:34px;
    z-index:999;
    box-shadow:0 10px 25px rgba(0,0,0,.3);
    transition:.3s;
}

.whatsapp:hover{
    transform:scale(1.08);
    color:#fff;
}

/*==========================
Tablet
==========================*/

@media(max-width:992px){

.navbar{
padding:12px 0;
}

.navbar-collapse{
padding-top:20px;
}

.navbar-nav{
text-align:center;
}

.navbar-nav .nav-link{
margin:12px 0;
}

.hero{
text-align:center;
}

.hero h1{
font-size:55px;
}

.hero p{
font-size:20px;
}

.hero-buttons{
justify-content:center;
}

.scroll-text{
display:none;
}

}

/*==========================
Mobile
==========================*/

@media(max-width:768px){

.hero{
padding-top:100px;
}

.hero-small{
font-size:14px;
}

.hero h1{
font-size:42px;
}

.hero p{
font-size:18px;
line-height:1.7;
}

.hero-buttons .btn{
width:100%;
}

#about h2{
font-size:32px;
}

.whatsapp{
width:55px;
height:55px;
font-size:28px;
right:15px;
bottom:15px;
}

}

/*==========================
Small Mobile
==========================*/

@media(max-width:480px){

.hero h1{
font-size:34px;
}

.hero p{
font-size:16px;
}

.hero-small{
letter-spacing:2px;
font-size:13px;
}

}


*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,Helvetica,sans-serif;
}

body{
    background:#f4f4f4;
    overflow-x:hidden;
}

.slider{
    width:100%;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:40px 20px;
}

.container1{
    position:relative;
    width:100%;
    max-width:1200px;
    height:520px;
    overflow:hidden;
}

.slide{
    position:absolute;
    top:50%;
    left:50%;
    width:420px;
    height:500px;
    border-radius:20px;
    overflow:hidden;
    transition:.6s ease;
    transform:translate(-50%,-50%);
    opacity:0;
    z-index:1;
}

.slide img{
    width:100%;
    height:100%;
    object-fit:cover;
}

/* Active */
.slide.active{
    transform:translate(-50%,-50%) scale(1);
    opacity:1;
    z-index:5;
    box-shadow:0 25px 60px rgba(0,0,0,.35);
}

/* Left */
.slide.left{
    transform:translate(-130%,-50%) scale(.82);
    opacity:.85;
    z-index:4;
}

/* Right */
.slide.right{
    transform:translate(30%,-50%) scale(.82);
    opacity:.85;
    z-index:4;
}

/* Far Left */
.slide.far-left{
    transform:translate(-215%,-50%) scale(.65);
    opacity:.45;
    z-index:2;
}

/* Far Right */
.slide.far-right{
    transform:translate(115%,-50%) scale(.65);
    opacity:.45;
    z-index:2;
}

.buttons{
    display:flex;
    gap:18px;
    margin-top:35px;
}

.buttons button{
    width:55px;
    height:55px;
    border-radius:50%;
    border:2px solid #222;
    background:#fff;
    cursor:pointer;
    font-size:20px;
    transition:.3s;
}

.buttons button:hover{
    background:#222;
    color:#fff;
}

/* Tablet */

@media(max-width:992px){

.container{
    height:430px;
}

.slide{
    width:320px;
    height:400px;
}

.slide.left{
    transform:translate(-115%,-50%) scale(.75);
}

.slide.right{
    transform:translate(15%,-50%) scale(.75);
}

.slide.far-left,
.slide.far-right{
    opacity:0;
}

}

/* Mobile */

@media(max-width:768px){

.container{
    height:340px;
}

.slide{
    width:240px;
    height:310px;
}

.slide.left,
.slide.right{
    opacity:.45;
    transform:translate(-85%,-50%) scale(.72);
}

.slide.right{
    transform:translate(-15%,-50%) scale(.72);
}

.slide.far-left,
.slide.far-right{
    display:none;
}

.buttons button{
    width:48px;
    height:48px;
}

}
</style>
